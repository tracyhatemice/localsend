# Public hostname Traefik exposes the stack on.
FQDN=example.org
ICE_SERVER_FQDN=example.org

# Sub-path prefix. Leading slash, NO trailing slash.
# Final URLs:
#   web:       https://${FQDN}${BASE_PATH}/
#   signaling: wss://${FQDN}${BASE_PATH}/v1/ws
BASE_PATH=/send

# Name of the external Docker network your standalone Traefik is attached to.
TRAEFIK_NETWORK=traefik

# ACME certificate resolver to use for TLS. Must be defined in your Traefik config.
CERTRESOLVER=letsencrypt

# ---- STUN/TURN (coturn) ----
# coturn serves BOTH STUN and TURN on the same port (3478 by default).
# Setting STUN_URL points the web client at your self-hosted STUN instead
# of the public Google STUN fallback.
#
# Leave both STUN_URL and TURN_URL empty to disable the /v1/turn-creds
# endpoint (404), in which case the web client uses its built-in default
# (public Google STUN, no TURN).
STUN_URL=stun:${ICE_SERVER_FQDN}:3478

# TURN bridges peers across IP families when no direct path exists
# (e.g., one IPv4-only and one IPv6-only on the same LAN).
# Format: turn:<host>:<port>  (optionally append ?transport=udp or ?transport=tcp)
TURN_URL=turn:${ICE_SERVER_FQDN}:3478

# Shared HMAC secret used by coturn's `use-auth-secret` mode. The signaling
# server uses this to mint short-lived TURN credentials (HMAC-SHA1 of a
# username:expiry pair). NOT user-facing — never embedded in the web bundle.
#
# Generate with: openssl rand -base64 48
TURN_AUTH_SECRET=CHANGE-ME-LONG-RANDOM-SECRET